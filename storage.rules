rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Verification documents: authenticated users can upload their own docs
    match /verificationDocs/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024  // 10MB max
        && (request.resource.contentType.matches('image/.*')
         || request.resource.contentType == 'application/pdf');
    }

    // Listing images: authenticated users can upload images for their listings
    match /listings/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 20 * 1024 * 1024  // 20MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Profile photos
    match /profiles/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
